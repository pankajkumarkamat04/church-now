PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/church_management
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Used in password-reset emails / logged reset links (no trailing slash)
FRONTEND_URL=http://localhost:3000

# Dev only: if true, POST /api/auth/forgot-password includes resetToken and resetLink in JSON (never enable in production)
PASSWORD_RESET_RETURN_TOKEN=false

# Optional superadmin seed overrides (defaults: admin@test.com / admin123)
# SUPERADMIN_EMAIL=admin@test.com
# SUPERADMIN_PASSWORD=admin123
